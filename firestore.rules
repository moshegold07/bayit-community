rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isActiveUser() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function touchesHiddenFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['hidden', 'hiddenAt', 'hiddenBy']);
    }

    match /formRegistrants/{regId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isActiveUser() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['claimed', 'claimedBy', 'claimedAt']));
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId &&
        request.resource.data.role == 'member' &&
        request.resource.data.status == 'pending';
      allow read: if isSignedIn();
      allow update: if isAdmin() ||
        (isSignedIn() && request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'role', 'score', 'referredCount', 'referredBy', 'lastReferralAt', 'shareClickCount', 'lastShareClickAt']));
      allow delete: if isAdmin();
    }

    match /phoneIndex/{phoneId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // archived 2026-05-02 — admin roadmap phase 0
    // match /events/{eventId} {
    //   allow read: if isSignedIn();
    //   allow create: if isActiveUser() &&
    //     request.resource.data.createdBy == request.auth.uid &&
    //     request.resource.data.title.size() <= 200 &&
    //     (!('description' in request.resource.data) || request.resource.data.description.size() <= 5000);
    //   allow update: if isActiveUser() &&
    //     (resource.data.createdBy == request.auth.uid || isAdmin()) &&
    //     (!touchesHiddenFields() || isAdmin()) &&
    //     request.resource.data.title.size() <= 200 &&
    //     (!('description' in request.resource.data) || request.resource.data.description.size() <= 5000);
    //   allow delete: if isAdmin() ||
    //     (isActiveUser() && resource.data.createdBy == request.auth.uid);
    // }

    // archived 2026-05-02 — admin roadmap phase 0
    // match /projects/{projectId} {
    //   allow read: if isSignedIn();
    //   allow create: if isActiveUser() &&
    //     request.resource.data.createdBy == request.auth.uid &&
    //     request.resource.data.title.size() <= 200 &&
    //     (!('description' in request.resource.data) || request.resource.data.description.size() <= 5000);
    //   allow update: if isActiveUser() &&
    //     (resource.data.createdBy == request.auth.uid || isAdmin()) &&
    //     (!touchesHiddenFields() || isAdmin()) &&
    //     request.resource.data.title.size() <= 200 &&
    //     (!('description' in request.resource.data) || request.resource.data.description.size() <= 5000);
    //   allow delete: if isAdmin() ||
    //     (isActiveUser() && resource.data.createdBy == request.auth.uid);
    //   match /comments/{commentId} {
    //     allow read: if isSignedIn();
    //     allow create: if isActiveUser() &&
    //       request.resource.data.authorId == request.auth.uid;
    //     allow update: if isAdmin() && touchesHiddenFields();
    //     allow delete: if isAdmin() ||
    //       (isActiveUser() && resource.data.authorId == request.auth.uid);
    //   }
    // }

    // archived 2026-05-02 — admin roadmap phase 0
    // match /resources/{resourceId} {
    //   allow read: if isSignedIn();
    //   allow create: if isActiveUser() &&
    //     request.resource.data.sharedBy == request.auth.uid &&
    //     request.resource.data.title.size() <= 200 &&
    //     (!('content' in request.resource.data) || request.resource.data.content.size() <= 5000);
    //   allow update: if isActiveUser() &&
    //     (resource.data.sharedBy == request.auth.uid || isAdmin()) &&
    //     (!touchesHiddenFields() || isAdmin()) &&
    //     request.resource.data.title.size() <= 200 &&
    //     (!('content' in request.resource.data) || request.resource.data.content.size() <= 5000);
    //   allow delete: if isAdmin() ||
    //     (isActiveUser() && resource.data.sharedBy == request.auth.uid);
    // }

    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /forums/{forumId} {
      allow read: if isSignedIn();
      allow create: if isActiveUser() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.title.size() <= 200 &&
        (!('description' in request.resource.data) || request.resource.data.description.size() <= 5000);
      allow update: if isActiveUser() &&
        (resource.data.createdBy == request.auth.uid || isAdmin()) &&
        (!touchesHiddenFields() || isAdmin()) &&
        request.resource.data.title.size() <= 200 &&
        (!('description' in request.resource.data) || request.resource.data.description.size() <= 5000);
      allow delete: if isAdmin() ||
        (isActiveUser() && resource.data.createdBy == request.auth.uid);
      match /posts/{postId} {
        allow read: if isSignedIn();
        allow create: if isActiveUser() &&
          request.resource.data.authorId == request.auth.uid;
        allow update: if isActiveUser() &&
          (!touchesHiddenFields() || isAdmin());
        allow delete: if isAdmin() ||
          (isActiveUser() && resource.data.authorId == request.auth.uid);
        match /replies/{replyId} {
          allow read: if isSignedIn();
          allow create: if isActiveUser() &&
            request.resource.data.authorId == request.auth.uid;
          allow update: if isAdmin() && touchesHiddenFields();
          allow delete: if isAdmin() ||
            (isActiveUser() && resource.data.authorId == request.auth.uid);
        }
      }
    }

    match /conversations/{convId} {
      allow read: if isActiveUser() &&
        request.auth.uid in resource.data.participants;
      allow create: if isActiveUser() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isActiveUser() &&
        request.auth.uid in resource.data.participants;
      match /messages/{msgId} {
        allow read: if isActiveUser() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isActiveUser() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow delete: if isAdmin();
      }
    }

    // archived 2026-05-02 — admin roadmap phase 0
    // match /polls/{pollId} {
    //   allow read: if isSignedIn();
    //   allow create: if isActiveUser() &&
    //     request.resource.data.createdBy == request.auth.uid;
    //   allow update: if isActiveUser() && (
    //     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes']) ||
    //     (isAdmin() && touchesHiddenFields())
    //   );
    //   allow delete: if isAdmin() ||
    //     (isActiveUser() && resource.data.createdBy == request.auth.uid);
    // }

    match /notifications/{notifId} {
      allow read: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if isActiveUser() &&
        request.resource.data.userId != request.auth.uid &&
        request.resource.data.keys().hasOnly(['userId', 'type', 'title', 'body', 'link', 'read', 'createdAt']);
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    match /endorsements/{endorseId} {
      allow read: if isSignedIn();
      allow create: if isActiveUser() &&
        request.resource.data.fromUid == request.auth.uid;
      allow delete: if isAdmin() ||
        (isActiveUser() && resource.data.fromUid == request.auth.uid);
    }

    match /activityFeed/{activityId} {
      allow read: if isSignedIn();
      allow create: if isActiveUser() &&
        request.resource.data.keys().hasOnly(['type', 'actorName', 'title', 'link', 'createdAt']);
    }

    match /tickets/{ticketId} {
      allow read: if isSignedIn();
      allow create: if isActiveUser() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Ventures are created only via the /api/claim-queue-number serverless
    // function, which uses the Firebase Admin SDK and bypasses these rules.
    // Direct client creates are denied so the queue counter stays atomic.
    match /ventures/{ventureId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /journeyPosts/{postId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 200;
      allow update: if isActiveUser()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.text.size() <= 200;
      allow delete: if isAdmin() || (isActiveUser() && resource.data.authorId == request.auth.uid);
    }

    match /referralClicks/{clickId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;  // server-only via admin SDK
    }
  }
}
